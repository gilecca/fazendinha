SECRET_KEY=gere-com-python-c-"from django.core.management.utils import get_random_secret_key;print(get_random_secret_key())"
DEBUG=False
ALLOWED_HOSTS=seudominio.com.br,www.seudominio.com.br
CSRF_TRUSTED_ORIGINS=https://seudominio.com.br

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Brevo (ex-Sendinblue) — https://app.brevo.com/settings/keys/smtp
# 1. Crie conta grátis em brevo.com (300 emails/dia)
# 2. Settings → Senders & IP → SMTP & API → gere uma SMTP Key
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=seu-login@brevo.com          # email de login no Brevo
EMAIL_HOST_PASSWORD=sua-smtp-key-aqui        # SMTP Key gerada no painel
DEFAULT_FROM_EMAIL=noreply@seudominio.com.br # domínio verificado no Brevo

# Railway gera automaticamente ao adicionar o plugin PostgreSQL
DATABASE_URL=postgresql://...
